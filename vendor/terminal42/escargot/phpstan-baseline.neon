parameters:
	ignoreErrors:
		-
			message: '#^Class Terminal42\\Escargot\\BaseUriCollection implements generic interface IteratorAggregate but does not specify its types\: TKey, TValue$#'
			identifier: missingType.generics
			count: 1
			path: src/BaseUriCollection.php

		-
			message: '#^Method Terminal42\\Escargot\\CrawlUri\:\:getTags\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/CrawlUri.php

		-
			message: '#^Property Terminal42\\Escargot\\CrawlUri\:\:\$tags type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/CrawlUri.php

		-
			message: '#^Property Terminal42\\Escargot\\Escargot\:\:\$decisionMap type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Escargot.php

		-
			message: '#^Property Terminal42\\Escargot\\Escargot\:\:\$runningRequests type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/Escargot.php

		-
			message: '#^Method Terminal42\\Escargot\\Queue\\InMemoryQueue\:\:getBaseUris\(\) should return Terminal42\\Escargot\\BaseUriCollection but returns array\<Psr\\Http\\Message\\UriInterface\>\.$#'
			identifier: return.type
			count: 1
			path: src/Queue/InMemoryQueue.php

		-
			message: '#^Parameter \#3 \$node of method Terminal42\\Escargot\\Subscriber\\HtmlCrawlerSubscriber\:\:addNewUriToQueueFromNode\(\) expects DOMElement, DOMNode\|null given\.$#'
			identifier: argument.type
			count: 1
			path: src/Subscriber/HtmlCrawlerSubscriber.php

		-
			message: '#^Method Terminal42\\Escargot\\SubscriberLogger\:\:log\(\) has parameter \$message with no type specified\.$#'
			identifier: missingType.parameter
			count: 1
			path: src/SubscriberLogger.php

		-
			message: '#^Call to an undefined method Terminal42\\Escargot\\Subscriber\\SubscriberInterface\:\:getUris\(\)\.$#'
			identifier: method.notFound
			count: 1
			path: tests/EscargotTest.php

		-
			message: '#^Call to method PHPUnit\\Framework\\Assert\:\:assertInstanceOf\(\) with ''Symfony\\\\Contracts\\\\HttpClient\\\\HttpClientInterface'' and Symfony\\Contracts\\HttpClient\\HttpClientInterface will always evaluate to true\.$#'
			identifier: method.alreadyNarrowedType
			count: 1
			path: tests/EscargotTest.php

		-
			message: '#^Method Terminal42\\Escargot\\Subscriber\\SubscriberInterface@anonymous/tests/EscargotTest\.php\:311\:\:getUris\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: tests/EscargotTest.php

		-
			message: '#^Method Terminal42\\Escargot\\Tests\\EscargotTest\:\:cleanLogs\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: tests/EscargotTest.php

		-
			message: '#^Method Terminal42\\Escargot\\Tests\\EscargotTest\:\:crawlProvider\(\) return type has no value type specified in iterable type iterable\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: tests/EscargotTest.php

		-
			message: '#^Method Terminal42\\Escargot\\Tests\\EscargotTest\:\:testCrawlAsWebCrawler\(\) has parameter \$expectedLogs with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
