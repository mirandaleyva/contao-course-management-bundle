		-
			message: '#^Method Terminal42\\Escargot\\Tests\\EscargotTest\:\:testCrawlAsWebCrawler\(\) has parameter \$options with no type specified\.$#'
			identifier: missingType.parameter
			count: 1
			path: tests/EscargotTest.php

		-
			message: '#^Property Terminal42\\Escargot\\Subscriber\\SubscriberInterface@anonymous/tests/EscargotTest\.php\:311\:\:\$uris type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: tests/EscargotTest.php

		-
			message: '#^Call to method PHPUnit\\Framework\\Assert\:\:assertInstanceOf\(\) with ''Generator'' and Generator will always evaluate to true\.$#'
			identifier: method.alreadyNarrowedType
			count: 2
