{% if empty %}
    <p>{{ labels.empty }}</p>
{% else %}
    <div class="course-list">
        {% for course in courses %}
            <article class="course-item">
                <h2>{{ course.title }}</h2>

                {% if course.author %}
                    <p><strong>{{ labels.author }}:</strong> {{ course.author }}</p>
                {% endif %}

                {% if course.description %}
                    <div class="course-description">
                        {{ course.description|raw }}
                    </div>
                {% endif %}

                <div class="course-dates">
                    <h3>{{ labels.course_dates }}</h3>
                    <ul>
                        {% for date in course.dates %}
                            <li>
                                <div>
                                    <strong>{{ labels.date }}:</strong>
                                    {{ date.start_date }}
                                    {% if date.end_date and date.end_date != date.start_date %}
                                        – {{ date.end_date }}
                                    {% endif %}
                                </div>

                                {% if date.add_time %}
                                    <div>
                                        <strong>{{ labels.time }}:</strong>
                                        {{ date.start_time }}{% if date.end_time %} – {{ date.end_time }}{% endif %}
                                    </div>
                                {% endif %}

                                {% if date.location %}
                                    <div>
                                        <strong>{{ labels.location }}:</strong>
                                        {{ date.location }}
                                    </div>
                                {% elseif date.venue %}
                                    <div>
                                        <strong>{{ labels.location }}:</strong>
                                        {{ date.venue }}
                                    </div>
                                {% endif %}

                                <div>
                                    <strong>{{ labels.status }}:</strong>
                                    {% if date.fully_booked %}
                                        {{ labels.fully_booked }}
                                    {% else %}
                                        {{ labels.available }}
                                    {% endif %}
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </article>
        {% endfor %}
    </div>
{% endif %}
